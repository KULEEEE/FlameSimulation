# Project-specific
# =============================================================================

# ImGui writes window state on every run; usually not worth tracking.
# (NOTE: SourceFiles/imgui.ini is already tracked in this repo. To stop
#  tracking it without deleting the file, run:
#       git rm --cached FlameSimulation/SourceFiles/imgui.ini)
imgui.ini
